# Ollama connection
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=embeddinggemma
COMBINER_MODEL=qwen3:8b
REFRAMER_MODEL=qwen3:8b
OLLAMA_GENERATOR_MODELS=gemma3:4b,huihui_ai/aya-expanse-abliterated:8b

# Language / request settings
# Internal pipeline text is currently handled in English.
OUTPUT_LANGUAGE=English
OLLAMA_TIMEOUT=180
REFRAMER_NUM_PREDICT=220

# Generation / mutation
GENERATOR_SAMPLE_COUNT=5
GENERATOR_MAX_WORKERS=3
GENERATOR_NUM_PREDICT=420
MUTATOR_NUM_PREDICT=360
MUTATION_COUNT=1

# Scoring / filtering
FILTER_SIMILARITY_THRESHOLD=0.82
SCORING_NEIGHBOR_COUNT=3
FILTER_USE_AGGRESSIVE_PRUNE=false

# Iterative search loop
SEARCH_MAX_GENERATIONS=2
PARENT_SELECTION_COUNT=3
COMBINATION_PAIR_COUNT=2
POOL_MAX_SIZE=10
POOL_MAX_PER_STRATEGY=2

# Optional behavior toggles
MUTATOR_ENFORCE_FAMILY=false

# Optional override:
# GENERATOR_PERSONAS=systems architect: obsessed with elegant systems...,contrarian founder: rejects conventional solutions...
