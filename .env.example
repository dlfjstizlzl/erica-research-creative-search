# Ollama connection
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=180

# -----------------------------------------------------
# ASYMMETRIC MODEL ARCHITECTURE
# -----------------------------------------------------
# 1. Synthesis & Base Generation (Recommend: Powerful models like Gemma 4, Command-R)
# Comma-separated model pool for base generation to ensure diverse initial seeds.
OLLAMA_GENERATOR_MODELS=gemma4:9b,llama3.1:8b
# The model that synthesizes combinations
COMBINER_MODEL=gemma4:9b

# 2. Perturbation & Analysis (Recommend: Structural models like Qwen 3, Llama 3)
# The model that generates mutations/deviations
MUTATOR_MODEL=qwen3:14b
# The model that analyzes and extracts conflicts between ideas
EXTRACTOR_MODEL=qwen3:14b
# The model that evaluates and scores the ideas (LLM-as-a-Judge)
JUDGE_MODEL=qwen3:14b
# The model that reframes the initial problem
REFRAMER_MODEL=qwen3:14b

# Fallback / Default
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=embeddinggemma
# -----------------------------------------------------

# Output Language
OUTPUT_LANGUAGE=Korean

# Token prediction limits
REFRAMER_NUM_PREDICT=220
GENERATOR_NUM_PREDICT=420
MUTATOR_NUM_PREDICT=360

# Pipeline hyperparameters
MUTATION_COUNT=1
GENERATOR_SAMPLE_COUNT=5
GENERATOR_MAX_WORKERS=3
FILTER_SIMILARITY_THRESHOLD=0.82
SCORING_NEIGHBOR_COUNT=3

# Iterative search loop
SEARCH_MAX_GENERATIONS=2
PARENT_SELECTION_COUNT=3
COMBINATION_PAIR_COUNT=2
POOL_MAX_SIZE=10
POOL_MAX_PER_STRATEGY=2

# Optional behavior toggles
MUTATOR_ENFORCE_FAMILY=false
FILTER_USE_AGGRESSIVE_PRUNE=false
